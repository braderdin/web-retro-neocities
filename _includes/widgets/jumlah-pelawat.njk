<div class="box visitor-box" style="text-align: center;">
    <h3 style="margin-bottom: 15px;">☕ POWERED BY KOPI O ☕</h3>
    <p style="margin-bottom: 10px;">📊 Jumlah Pelawat Garaj:</p>
    
    <!-- Kaunter Digital Retro (Mengekalkan Rupa Asal & Bermula dari 77) -->
    <div style="font-family: monospace; font-size: 1.8rem; letter-spacing: 8px; background: #111; color: #00ffcc; padding: 10px 15px; border: 3px inset #555; display: inline-block; border-radius: 3px; font-weight: bold; text-shadow: 0 0 5px #00ffcc;">
        <span id="retro-counter">00077</span>
    </div>

    <script>
        (function() {
            // ID unik tersendiri untuk mengelakkan pertembungan data kaunter lama
            const namespace = "braderdin.neocities.org";
            const key = "garaj_counter_final"; 
            const url = `https://api.counterapi.dev/v1/${namespace}/${key}/up`;

            // Tetapkan nilai pandangan asal (views) dari Neocities sebagai asas
            const baseViews = 77;

            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data && data.count) {
                        // Jumlahkan statistik hidup API bersama dengan 77 views sedia ada anda
                        let totalViews = data.count + baseViews;
                        let countString = totalViews.toString().padStart(5, '0');
                        document.getElementById('retro-counter').textContent = countString;
                    } else {
                        document.getElementById('retro-counter').textContent = baseViews.toString().padStart(5, '0');
                    }
                })
                .catch(error => {
                    console.error("Gagal memuatkan hit counter:", error);
                    // Jika API mengalami gangguan, ia tetap memaparkan angka asas 77 secara selamat
                    document.getElementById('retro-counter').textContent = baseViews.toString().padStart(5, '0');
                });
        })();
    </script>
</div>
